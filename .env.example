# AIPlex Local Development Environment Variables
#
# Copy to .env and modify:
#   cp .env.example .env
#
# Used by: make run-local, docker-compose

# ── API Server ──────────────────────────────────────────

AIPLEX_HOST=0.0.0.0
AIPLEX_PORT=8080
LOG_LEVEL=debug

# ── Auth (Ory Hydra) ───────────────────────────────────

HYDRA_ADMIN_URL=http://localhost:4445

# ── Firestore ──────────────────────────────────────────

# For local dev with emulator:
FIRESTORE_EMULATOR_HOST=localhost:8086
FIRESTORE_PROJECT_ID=aiplex-dev

# For production (remove emulator host):
# GCP_PROJECT_ID=my-gcp-project

# ── Identity ───────────────────────────────────────────

TRUST_DOMAIN=aiplex-dev.svc.id.goog

# ── CLI ────────────────────────────────────────────────

# Used by aiplex CLI when --url/--token not specified:
# AIPLEX_URL=http://localhost:8080
# AIPLEX_TOKEN=your-jwt-token
